{
  "name": "radio-cast",
  "private": true,
  "version": "0.0.1",
  "description": "Radio Cast desktop and web console for radio automation.",
  "author": "Mauro Polini",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "dev:desktop": "concurrently -k \"npm run dev\" \"wait-on http://127.0.0.1:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "build": "cross-env APP_BASE=/RadioCast/ vite build",
    "build:desktop": "cross-env APP_BASE=./ vite build",
    "preview": "vite preview",
    "dist:dir": "npm run build:desktop && electron-builder --dir --publish never",
    "dist:mac": "npm run build:desktop && electron-builder --mac dmg --publish never",
    "dist:win": "npm run build:desktop && electron-builder --win nsis --publish never"
  },
  "dependencies": {
    "lucide-react": "^0.511.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "png-to-ico": "^3.0.1",
    "vite": "^8.0.6",
    "wait-on": "^9.0.5"
  },
  "build": {
    "appId": "com.radiocast.desktop",
    "productName": "Radio Cast",
    "asar": true,
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "mac": {
      "icon": "build/icon.icns",
      "target": [
        "dmg"
      ],
      "artifactName": "RadioCast-${version}-${arch}.${ext}"
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "RadioCast-${version}-Setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false
    }
  }
}
